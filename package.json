{
  "name": "said-cipher",
  "version": "1.0.0",
  "description": "S.A.I.D. Cipher — MYM Logic LLC",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w node-pty,better-sqlite3",
    "postinstall": "electron-rebuild -f -w node-pty,better-sqlite3",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.mymlogic.said-cipher",
    "productName": "S.A.I.D. Cipher",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": ["**/*", "!node_modules/.cache"]
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.0.0",
    "openai": "^4.28.0",
    "uuid": "^9.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "@electron/rebuild": "^3.6.0"
  }
}
